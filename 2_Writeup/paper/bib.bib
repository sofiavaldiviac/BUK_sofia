	pages = {959--1006},
	file = {Full Text PDF:/Users/sofiavaldivia/Zotero/storage/E6C7H86U/Lang and Lehmann - 2012 - Racial Discrimination in the Labor Market Theory and Empirics.pdf:application/pdf},
